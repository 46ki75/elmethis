    "elm-text-field": "ElmTextField",
    "elm-validation": "ElmValidation",
    "elm-copy-icon": "ElmCopyIcon",
    "elm-dot-loading-icon": "ElmDotLoadingIcon",
    "elm-inline-icon": "ElmInlineIcon",
    "elm-language-icon": "ElmLanguageIcon",
    "elm-mdi-icon": "ElmMdiIcon",
    "elm-square-loading-icon": "ElmSquareLoadingIcon",
