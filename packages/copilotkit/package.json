{
    "name": "backend",
    "version": "1.0.0",
    "description": "CopilotKit Backend",
    "main": "index.ts",
    "type": "module",
    "scripts": {
        "dev": "PORT=19101 node --env-file=.env --watch ./src/server.ts",
        "prestart": "pnpm run build",
        "start": "node ./dist/copilotkit-builtin.mjs",
        "build": "node build.ts",
        "prebuild:container": "pnpm run build",
        "build:container": "docker buildx build -t copilotkit-minimal --platform linux/arm64 ."
    },
    "dependencies": {
        "@ag-ui/mastra": "^1.0.2",
        "@ai-sdk/openai": "^3.0.63",
        "@copilotkit/runtime": "^1.57.1",
        "@copilotkit/shared": "^1.57.1",
        "@hono/node-server": "^2.0.2",
        "@mastra/core": "^1.32.1",
        "@openrouter/ai-sdk-provider": "^2.9.0",
        "agent": "link:@mastra/core/agent",
        "dotenv": "^17.4.2",
        "hono": "^4.12.18",
        "openai": "^6.37.0"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "esbuild": "^0.28.0",
        "typescript": "^5.6.2"
    }
}