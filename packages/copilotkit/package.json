{
    "name": "backend",
    "version": "1.0.0",
    "description": "CopilotKit Backend",
    "main": "index.ts",
    "type": "module",
    "scripts": {
        "dev": "PORT=19101 node --env-file=.env --watch ./src/index.ts",
        "prestart": "pnpm run build",
        "start": "node ./dist/index.js",
        "build": "node build.ts",
        "prebuild:container": "pnpm run build",
        "build:container": "docker buildx build -t copilotkit-minimal --platform linux/arm64 ."
    },
    "dependencies": {
        "@ai-sdk/openai": "^3.0.52",
        "@copilotkit/runtime": "^1.55.3",
        "@copilotkit/shared": "^1.55.3",
        "@hono/node-server": "^1.19.14",
        "@openrouter/ai-sdk-provider": "^2.5.1",
        "dotenv": "^16.4.5",
        "hono": "^4.12.12",
        "openai": "^4.104.0"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "esbuild": "^0.28.0",
        "typescript": "^5.6.2"
    }
}