{
    "name": "backend",
    "version": "1.0.0",
    "description": "CopilotKit Backend",
    "main": "index.ts",
    "type": "module",
    "scripts": {
        "dev": "PORT=19101 node --env-file=.env --watch ./src/index.ts",
        "prestart": "pnpm run build",
        "start": "node ./dist/index.js",
        "build": "node build.ts",
        "prebuild:container": "pnpm run build",
        "build:container": "docker buildx build -t copilotkit-minimal --platform linux/arm64 ."
    },
    "dependencies": {
        "@ag-ui/client": "latest",
        "@ag-ui/encoder": "latest",
        "@ag-ui/mastra": "^1.0.2",
        "@hono/node-server": "^1.19.14",
        "@mastra/core": "^1.28.0",
        "@mastra/hono": "latest",
        "@mastra/mcp": "^1.5.2",
        "@openrouter/ai-sdk-provider": "^2.5.1",
        "dotenv": "^16.4.5",
        "hono": "^4.12.12"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "esbuild": "^0.28.0",
        "typescript": "^5.6.2"
    }
}