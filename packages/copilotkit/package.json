{
    "name": "backend",
    "version": "1.0.0",
    "description": "CopilotKit Backend (Claude Agent SDK)",
    "main": "index.ts",
    "type": "module",
    "scripts": {
        "dev": "PORT=19101 node --env-file=.env --watch ./src/server.ts",
        "prestart": "pnpm run build",
        "start": "node ./dist/index.mjs",
        "build": "node build.ts",
        "prebuild:container": "pnpm run build",
        "build:container": "docker buildx build -t copilotkit-minimal --platform linux/arm64 ."
    },
    "dependencies": {
        "@ag-ui/claude-agent-sdk": "^0.0.3",
        "@ag-ui/client": "0.0.57",
        "@ag-ui/core": "0.0.57",
        "@anthropic-ai/claude-agent-sdk": "^0.2.58",
        "@anthropic-ai/sdk": "^0.93.0",
        "@copilotkit/runtime": "^1.61.2",
        "@copilotkit/shared": "^1.61.0",
        "@hono/node-server": "^2.0.5",
        "@modelcontextprotocol/sdk": "^1.29.0",
        "consola": "^3.4.2",
        "dotenv": "^17.4.2",
        "hono": "^4.12.25",
        "zod": "^4.0.0"
    },
    "devDependencies": {
        "@types/node": "^26.0.0",
        "esbuild": "^0.28.1",
        "typescript": "^5.6.2"
    }
}
