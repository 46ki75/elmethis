{
  "name": "@elmethis/core",
  "version": "0.9.2",
  "author": {
    "name": "Ikuma Yamashita",
    "url": "https://www.ikuma.cloud/"
  },
  "description": "Framework-agnostic shared types and schemas for the @elmethis component libraries.",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": "^18.17.0 || ^20.3.0 || >=21.0.0"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsdown && tsx scripts/emit-catalog.ts",
    "dev": "tsdown --watch",
    "fmt": "prettier --write .",
    "fmt.check": "prettier --check .",
    "test.unit": "vitest --run",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "@a2ui/web_core": ">=0.10.0",
    "zod": "^3"
  },
  "dependencies": {
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@a2ui/web_core": "^0.10.0",
    "@types/node": "25.7.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "prettier": "3.8.3",
    "tsdown": "^0.22.1",
    "tsx": "^4.20.7",
    "typescript": "5.9.3",
    "vitest": "^4.1.6",
    "zod": "^3"
  }
}