{
  "name": "@elmethis/core",
  "version": "0.9.0",
  "description": "Framework-agnostic shared types and schemas for the @elmethis component libraries.",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": "^18.17.0 || ^20.3.0 || >=21.0.0"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "fmt": "prettier --write .",
    "fmt.check": "prettier --check ."
  },
  "peerDependencies": {
    "@a2ui/web_core": ">=0.10.0",
    "zod": "^3"
  },
  "devDependencies": {
    "@a2ui/web_core": "^0.10.0",
    "prettier": "3.8.3",
    "tsdown": "^0.22.0",
    "typescript": "5.9.3",
    "zod": "^3"
  }
}