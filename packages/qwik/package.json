{
  "name": "@elmethis/qwik",
  "version": "0.1.0-alpha.3",
  "publishConfig": {
    "access": "public"
  },
  "description": "Create a Qwik library",
  "main": "./lib/index.qwik.mjs",
  "qwik": "./lib/index.qwik.mjs",
  "types": "./lib-types/index.d.ts",
  "module": "./lib/index.qwik.mjs",
  "exports": {
    ".": {
      "types": "./lib-types/index.d.ts",
      "import": {
        "types": "./lib-types/index.d.ts",
        "default": "./lib/index.qwik.mjs"
      },
      "require": {
        "types": "./lib-types/index.d.ts",
        "default": "./lib/index.qwik.cjs"
      }
    },
    "./style.css": {
      "default": "./lib/style.css"
    }
  },
  "files": [
    "lib",
    "lib-types"
  ],
  "engines": {
    "node": "^18.17.0 || ^20.3.0 || >=21.0.0"
  },
  "private": false,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "qwik build",
    "build-storybook": "storybook build",
    "build.lib": "vite build --mode lib",
    "build.types": "tsc --emitDeclarationOnly --incremental false",
    "dev": "storybook dev -p 19211 --no-open",
    "fmt": "prettier --write .",
    "fmt.check": "prettier --check .",
    "lint": "eslint \"src/**/*.ts*\"",
    "prepublishOnly": "pnpm run build",
    "release": "np",
    "start": "vite --open --mode ssr",
    "test.unit": "vitest --run",
    "test.unit.ui": "vitest --ui",
    "qwik": "qwik"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@qwik.dev/core": "2.0.0-beta.35",
    "@storybook/addon-docs": "^10.4.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "25.7.0",
    "@vitest/ui": "^4.1.6",
    "eslint": "10.4.0",
    "eslint-plugin-qwik": "2.0.0-beta.35",
    "globals": "17.6.0",
    "happy-dom": "^20.9.0",
    "jarkup-ts": "^0.14.0",
    "np": "^11.2.1",
    "prettier": "3.8.3",
    "storybook": "^10.4.0",
    "storybook-framework-qwik": "0.6.2--canary.95.25602496384.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.3",
    "undici": "*",
    "vite": "^7",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@a2ui/web_core": "^0.10.0",
    "@elmethis/core": "workspace:^",
    "@ag-ui/client": "^0.0.53",
    "@ag-ui/core": "^0.0.53",
    "@formkit/auto-animate": "^0.9.0",
    "@mdi/js": "^7.4.47",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "es-toolkit": "^1.46.1",
    "katex": "^0.16.47",
    "marked": "^18.0.3",
    "polished": "^4.3.1",
    "shiki": "^4.0.2",
    "uuid": "^14.0.0",
    "zod": "^3",
    "zod-to-json-schema": "^3.25.2"
  },
  "peerDependencies": {
    "@qwik.dev/core": ">=2.0.0-beta.31"
  }
}