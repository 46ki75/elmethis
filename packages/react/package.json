{
  "name": "@elmethis/react",
  "version": "0.3.21",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "author": "Ikuma Yamashita",
  "repository": {
    "type": "git",
    "url": "git@github.com:46ki75/elmethis.git"
  },
  "main": "./lib/index.react.mjs",
  "react": "./lib/index.react.mjs",
  "types": "./lib-types/index.d.ts",
  "module": "./lib/index.react.mjs",
  "exports": {
    ".": {
      "types": "./lib-types/lib.d.ts",
      "import": {
        "types": "./lib-types/lib.d.ts",
        "default": "./lib/index.react.mjs"
      },
      "require": {
        "types": "./lib-types/lib.d.ts",
        "default": "./lib/index.react.cjs"
      }
    },
    "./style.css": {
      "default": "./lib/style.css"
    }
  },
  "files": [
    "lib",
    "lib-types"
  ],
  "scripts": {
    "prepublishOnly": "pnpm run build",
    "build": "tsc --noEmit && vite build && pnpm run build.types",
    "build.types": "tsc --project tsconfig.lib.json && tsc-alias --project tsconfig.lib.json",
    "lint": "eslint .",
    "format": "prettier --write ./src",
    "dev": "storybook dev -p 19221 --no-open",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@iconify-json/devicon": "^1.2.62",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify/react": "^6.0.2",
    "@mdi/js": "^7.4.47",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "clsx": "^2.1.1",
    "jarkup-ts": "^0.14.0",
    "katex": "^0.16.45",
    "lodash-es": "^4.18.1",
    "marked": "^18.0.2",
    "mermaid": "^11.14.0",
    "polished": "^4.3.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "shiki": "^4.0.2"
  },
  "devDependencies": {
    "@copilotkit/react-core": "^1.56.5",
    "@eslint/js": "^10.0.1",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "prettier": "3.8.3",
    "storybook": "^10.3.6",
    "tsc-alias": "^1.8.16",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.4"
  }
}