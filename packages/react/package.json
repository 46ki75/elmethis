{
  "name": "@elmethis/react",
  "version": "0.3.1",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "author": "Ikuma Yamashita",
  "repository": {
    "type": "git",
    "url": "git@github.com:46ki75/elmethis.git"
  },
  "main": "./lib/index.react.mjs",
  "react": "./lib/index.react.mjs",
  "types": "./lib-types/index.d.ts",
  "module": "./lib/index.react.mjs",
  "exports": {
    ".": {
      "types": "./lib-types/lib.d.ts",
      "import": {
        "types": "./lib-types/lib.d.ts",
        "default": "./lib/index.react.mjs"
      },
      "require": {
        "types": "./lib-types/lib.d.ts",
        "default": "./lib/index.react.cjs"
      }
    },
    "./style.css": {
      "default": "./lib/style.css"
    }
  },
  "files": [
    "lib",
    "lib-types"
  ],
  "scripts": {
    "build": "tsc -b && vite build && pnpm run build.types",
    "build.types": "tsc --project tsconfig.lib.json",
    "lint": "eslint ."
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  },
  "peerDependencies": {}
}