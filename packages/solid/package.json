{
  "name": "@elmethis/solid",
  "version": "0.4.0",
  "description": "SolidJS component library for elmethis.",
  "publishConfig": {
    "access": "public"
  },
  "private": false,
  "type": "module",
  "author": "Ikuma Yamashita",
  "repository": {
    "type": "git",
    "url": "git@github.com:46ki75/elmethis.git"
  },
  "homepage": "https://46ki75.github.io/elmethis",
  "main": "./lib/index.solid.cjs",
  "module": "./lib/index.solid.mjs",
  "types": "./lib-types/exports.d.ts",
  "exports": {
    ".": {
      "types": "./lib-types/exports.d.ts",
      "solid": "./lib-solid/index.js",
      "import": {
        "types": "./lib-types/exports.d.ts",
        "default": "./lib/index.solid.mjs"
      },
      "require": {
        "types": "./lib-types/exports.d.ts",
        "default": "./lib/index.solid.cjs"
      }
    },
    "./style.css": {
      "default": "./lib/style.css"
    }
  },
  "files": [
    "lib",
    "lib-solid",
    "lib-types"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "engines": {
    "node": "^18.17.0 || ^20.3.0 || >=21.0.0"
  },
  "scripts": {
    "build": "pnpm run build.lib && pnpm run build.solid && pnpm run build.types",
    "build.lib": "vite build",
    "build.solid": "tsc --project tsconfig.solid.json && node scripts/copy-solid-assets.mjs",
    "build.types": "tsc --project tsconfig.lib.json",
    "build-storybook": "storybook build",
    "dev": "storybook dev -p 19241 --no-open",
    "dev.lib": "vite build --watch",
    "fmt": "prettier --write ./src",
    "fmt.check": "prettier --check ./src",
    "lint": "eslint \"src/**/*.ts*\"",
    "lint.css": "stylelint \"{src,.storybook}/**/*.css\"",
    "test": "pnpm run test.unit && pnpm run test.browser",
    "test.unit": "vitest --run && vitest --run --config vitest.ssr.config.ts",
    "test.coverage": "vitest --run --coverage && vitest --run --config vitest.ssr.config.ts",
    "test.browser": "vitest --run --config vitest.browser.config.ts",
    "test.coverage.browser": "vitest --run --coverage --config vitest.browser.config.ts",
    "test.package": "node scripts/test-package.mjs",
    "test.build": "pnpm run build && pnpm run build-storybook",
    "check": "concurrently -g \"pnpm:fmt.check\" \"pnpm:lint\" \"pnpm:lint.css\" \"pnpm:build.types\"",
    "check.ci": "concurrently -g \"pnpm:check\" \"pnpm:test.build\" \"pnpm:test.unit\" \"pnpm:test.browser\"",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "solid-js": "^1.9.0"
  },
  "dependencies": {
    "@46ki75/ikuma-theme": "^0.0.10",
    "@a2ui/web_core": "^0.10.5",
    "@ag-ui/client": "^0.0.57",
    "@ag-ui/core": "^0.0.57",
    "@mdi/js": "^7.4.47",
    "@elmethis/core": "workspace:^",
    "@formkit/auto-animate": "^0.10.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "clsx": "^2.1.1",
    "katex": "^0.17.0",
    "marked": "^18.0.6",
    "shiki": "^4.3.1",
    "uuid": "^14.0.1",
    "zod": "^3",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@elmethis/ag-ui-stub": "workspace:^",
    "@eslint/js": "latest",
    "@solidjs/testing-library": "^0.8.10",
    "@storybook/addon-docs": "^10.5.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/katex": "^0.16.8",
    "@types/node": "^26.1.1",
    "@vitest/browser-playwright": "4.1.10",
    "@vitest/coverage-v8": "4.1.10",
    "concurrently": "^10.0.3",
    "eslint": "^10.7.0",
    "eslint-plugin-solid": "~0.14.5",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "playwright": "^1.61.1",
    "prettier": "3.9.5",
    "solid-js": "^1.9.14",
    "storybook": "^10.5.2",
    "storybook-solidjs-vite": "^10.5.2",
    "stylelint": "^17.14.0",
    "stylelint-config-css-modules": "^4.6.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-value-no-unknown-custom-properties": "^6.1.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.0.4",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "4.1.10"
  }
}
